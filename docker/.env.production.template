# =============================================================================
# Docker 生产环境配置模板 / Docker Production Environment Template
# =============================================================================
# 使用方法 / Usage:
#   cp .env.production.template .env.production
#   # 编辑 .env.production 设置所有必要的值
#   # Edit .env.production to set all required values
#   docker compose --env-file .env.production up -d

# =============================================================================
# ============ 项目配置 / Project Configuration ============
# =============================================================================
PROJECT_NAME=personal_ai

# =============================================================================
# ============ 端口配置 / Port Configuration ============
# =============================================================================
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_PUBLISH_PORT=8000
DB_PORT=127.0.0.1:5432
REDIS_PORT=127.0.0.1:6379

# =============================================================================
# ============ 数据库配置 / Database Configuration ============
# =============================================================================
POSTGRES_DB=personal_ai
POSTGRES_USER=admin
# ⚠️ 必须设置强密码 / MUST SET strong password
# 生成命令 / Generate: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# =============================================================================
# ============ Redis 配置 / Redis Configuration ============
# =============================================================================
# ⚠️ 必须设置强密码 / MUST SET strong password
# 生成命令 / Generate: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION

# =============================================================================
# ============ 后端配置 / Backend Configuration ============
# =============================================================================
BACKEND_SRC_DIR=../backend
BACKEND_ENV_FILE=../backend/.env.production
BACKEND_CMD=gunicorn app.main:app --worker-class uvicorn.workers.UvicornWorker --bind 0.0.0.0:8000 --workers 4 --timeout 120 --log-level info

# =============================================================================
# ============ Nginx 配置 / Nginx Configuration ============
# =============================================================================
NGINX_CONF_DIR=./nginx
NGINX_CERT_DIR=./nginx/cert
NGINX_LOG_DIR=./nginx/logs
HTTPS_MODE=https
DOMAIN=your-domain.com
SSL_CERT_PATH=/etc/nginx/cert/fullchain.pem
SSL_KEY_PATH=/etc/nginx/cert/privkey.pem
NGINX_CERT_DIR=/etc/letsencrypt/live/your-domain.com

# 调试模式 - 生产环境必须为 false / Debug mode - MUST be false in production
DEBUG_CONFIG=false

# =============================================================================
# ============ 存储路径配置 / Storage Path Configuration ============
# =============================================================================
LOG_DIR=./logs
TRANSCRIPTION_TEMP_DIR=./temp/transcription
TRANSCRIPTION_STORAGE_DIR=./storage/podcasts

# =============================================================================
# ============ 时区配置 / Timezone Configuration ============
# =============================================================================
TZ=Asia/Shanghai

# =============================================================================
# ============ Celery 配置 / Celery Configuration ============
# =============================================================================
CELERY_WORKERS=4
CELERY_LOG_LEVEL=info
