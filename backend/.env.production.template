# =============================================================================
# 后端生产环境配置模板 / Backend Production Environment Template
# =============================================================================
# 使用方法 / Usage:
#   cp .env.production.template .env.production
#   # 编辑 .env.production 设置所有必要的值
#   # Edit .env.production to set all required values

# Application
PROJECT_NAME=personal_ai
VERSION=1.0.0
API_V1_STR=/api/v1
ENVIRONMENT=production

# ⚠️ 必须设置 SECRET_KEY / MUST SET SECRET_KEY
# 生成命令 / Generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# Database
POSTGRES_DB=personal_ai
POSTGRES_USER=admin
# ⚠️ 必须设置强密码 / MUST SET strong password
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
DATABASE_URL=postgresql+asyncpg://admin:CHANGE_ME_IN_PRODUCTION@postgres:5432/personal_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis - 密码从 Docker 环境变量传入 / Password passed from Docker env
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# CORS - ⚠️ 必须指定具体域名 / MUST specify exact domains
# 多个域名用逗号分隔 / Multiple domains separated by comma
ALLOWED_HOSTS=https://your-domain.com,https://www.your-domain.com

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Celery
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# External APIs
OPENAI_API_BASE_URL=https://api.openai.com/v1

# File storage
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
DATA_DIR=data

# Podcast Features
LLM_CONTENT_SANITIZE_MODE=strict

# Transcription
TRANSCRIPTION_API_URL=https://api.siliconflow.cn/v1/audio/transcriptions
# ⚠️ 必须设置 API Key / MUST SET API Key
TRANSCRIPTION_API_KEY=CHANGE_ME_IN_PRODUCTION
TRANSCRIPTION_CHUNK_SIZE_MB=10
TRANSCRIPTION_TARGET_FORMAT=mp3
TRANSCRIPTION_TEMP_DIR=./temp/transcription
TRANSCRIPTION_STORAGE_DIR=./storage/podcasts
TRANSCRIPTION_MAX_THREADS=4

# Admin Panel
ADMIN_2FA_ENABLED=true
