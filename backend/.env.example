# =============================================================================
# Backend Application Configuration Template
# =============================================================================
#
# Usage:
#   1. Copy this file to .env: cp .env.example .env
#   2. Fill in values marked with CHANGE_ME
#   3. cd backend && uv run uvicorn app.main:app --reload
#
# For Docker deployment, use docker/.env instead.

# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=development
VERSION=1.0.0
API_V1_STR=/api/v1
DEBUG=false

# =============================================================================
# Authentication
# =============================================================================
# API_KEY: Required for API access. Generate: openssl rand -hex 32
API_KEY=CHANGE_ME
# SECRET_KEY: Used for signing cookies, encrypting stored API keys, etc.
# Auto-generated if not set, but changing it invalidates existing encrypted data.
# Generate: openssl rand -hex 32
# SECRET_KEY=

# =============================================================================
# Database
# =============================================================================
# PostgreSQL with asyncpg driver
# Docker: postgresql+asyncpg://admin:password@postgres:5432/personal_ai
DATABASE_URL=postgresql+asyncpg://admin:password@localhost:5432/personal_ai
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# CORS
# =============================================================================
# MUST set to your actual domain in production. ["*"] is development only.
# Production example: ["https://my-podcast.example.com"]
ALLOWED_HOSTS=["http://localhost:8000"]

# =============================================================================
# External APIs
# =============================================================================
# OpenAI (or compatible) API
OPENAI_API_KEY=CHANGE_ME
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Transcription API (SiliconFlow, optional)
TRANSCRIPTION_API_URL=https://api.siliconflow.cn/v1/audio/transcriptions
# TRANSCRIPTION_API_KEY=

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=30

# =============================================================================
# Podcast Features
# =============================================================================
MAX_PODCAST_SUBSCRIPTIONS=0
RSS_POLL_INTERVAL_MINUTES=60
PODCAST_FEED_LIGHTWEIGHT_ENABLED=true

# =============================================================================
# Transcription
# =============================================================================
TRANSCRIPTION_CHUNK_SIZE_MB=10
TRANSCRIPTION_TARGET_FORMAT=mp3
TRANSCRIPTION_MAX_THREADS=4
TRANSCRIPTION_BACKLOG_ENABLED=true
TRANSCRIPTION_BACKLOG_BATCH_SIZE=20
TRANSCRIPTION_BACKLOG_SCHEDULE_MINUTE=5

# =============================================================================
# AI Client
# =============================================================================
AI_CLIENT_MAX_RETRIES=3
AI_CLIENT_BASE_DELAY=2
